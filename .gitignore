# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Sentry
.sentrycli

# Misc
coverage/
.nyc_output/
*.log

# Optional: ignore nested git folders if any were accidentally committed
**/.git/

# Keep examples and docs tracked
!.env.example

# Local test outputs
*.local

# Temporary files
*.tmp
*~

